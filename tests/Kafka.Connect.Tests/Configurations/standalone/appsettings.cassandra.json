{
  "worker": {
    "connectors": {
      "cassandra-sink-connector": {
        "groupId": "standalone-cassandra-sink-connector",
        "topics": ["standalone-cassandra-sink-data-topic"],
        "tasks": 1,
        "paused": false,
        "disabled": false,
        "processors": {
          "1": {
            "name": "Kafka.Connect.Processors.WhitelistFieldProjector",
            "settings": [
              "userId",
              "userName",
              "email",
              "timestamp",
              "action"
            ]
          }
        },
        "plugin": {
          "type": "sink",
          "name": "cassandra",
          "handler": "Kafka.Connect.Cassandra.CassandraPluginHandler",
          "strategy": {
            "name": "Kafka.Connect.Cassandra.Strategies.UpsertStrategy"
          },
          "properties": {
            "hosts": ["cassandra"],
            "port": 9042,
            "keyspace": "kafka_connect_db",
            "table": "standalone_cassandra_sink_data_table",
            "lookup": "\"userId\"='#userId#'",
            "filter": "\"userId\"='#userId#'"
          }
        },
        "log": {
          "provider": "",
          "attributes": [
            "userId",
            "userName"
          ]
        }
      },
      "cassandra-source-connector": {
        "groupId": "standalone-cassandra-source-connector",
        "tasks": 1,
        "paused": false,
        "disabled": false,
        "plugin": {
          "type": "source",
          "name": "cassandra",
          "handler": "Kafka.Connect.Cassandra.CassandraPluginHandler",
          "strategy": {
            "name": "Kafka.Connect.Cassandra.Strategies.ReadStrategy"
          },
          "properties": {
            "hosts": ["cassandra"],
            "port": 9042,
            "keyspace": "kafka_connect_db",
            "commands": {
              "standalone-cassandra-source-command": {
                "topic": "standalone-cassandra-source-data-topic",
                "table": "standalone_cassandra_source_data_table",
                "keyspace": "kafka_connect_db",
                "keys": ["userId"],
                "filters": {
                  "userId": ""
                },
                "snapshot": {
                  "enabled": false,
                  "key": "userId"
                }
              }
            }
          }
        },
        "log": {
          "provider": "",
          "attributes": [
            "id",
            "timestamp",
            "operation",
            "after.userId",
            "after.userName",
            "after.email"
          ]
        }
      }
    }
  }
}
