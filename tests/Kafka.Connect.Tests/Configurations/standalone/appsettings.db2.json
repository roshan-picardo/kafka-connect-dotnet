{
  "worker": {
    "connectors": {
      "db2-sink-connector": {
        "groupId": "standalone-db2-sink-connector",
        "topics": ["standalone-db2-sink-data-topic"],
        "tasks": 1,
        "paused": false,
        "disabled": false,
        "processors": {
          "1": {
            "name": "Kafka.Connect.Processors.WhitelistFieldProjector",
            "settings": [
              "userId",
              "userName",
              "email",
              "timestamp",
              "action"
            ]
          }
        },
        "plugin": {
          "type": "sink",
          "name": "db2",
          "handler": "Kafka.Connect.Db2.Db2PluginHandler",
          "strategy": {
            "Name": "Kafka.Connect.Db2.Strategies.UpsertStrategy"
          },
          "properties": {
            "server": "db2",
            "port": 50000,
            "userId": "db2inst1",
            "password": "db2password",
            "database": "kafka_connect_db",
            "schema": "DB2INST1",
            "table": "standalone_db2_sink_data_table",
            "lookup": "\"userId\"='#userId#'",
            "filter": "\"userId\"='#userId#'"
          }
        },
        "log": {
          "provider": "",
          "attributes": [
            "timestamp",
            "operation",
            "after.id",
            "after.name",
            "id",
            "name"
          ]
        }
      },
      "db2-source-connector": {
        "groupId": "standalone-db2-source-connector",
        "tasks": 1,
        "paused": false,
        "disabled": false,
        "plugin": {
          "type": "source",
          "name": "db2",
          "handler": "Kafka.Connect.Db2.Db2PluginHandler",
          "strategy": {
            "name": "Kafka.Connect.Db2.Strategies.ReadStrategy"
          },
          "properties": {
            "server": "db2",
            "port": 50000,
            "userId": "db2inst1",
            "password": "db2password",
            "database": "kafka_connect_db",
            "changelog": {
              "schema": "DB2INST1",
              "table": "standalone_db2_audit_log"
            },
            "commands": {
              "standalone-db2-source-command": {
                "topic": "standalone-db2-source-data-topic",
                "table": "standalone_db2_source_data_table",
                "schema": "DB2INST1",
                "keys": ["userId"],
                "snapshot": {
                  "enabled": false,
                  "key": "userId"
                }
              }
            }
          }
        },
        "log": {
          "provider": "",
          "attributes": [
            "id",
            "timestamp",
            "operation",
            "after.userId",
            "after.userName",
            "after.email"
          ]
        }
      }
    }
  }
}