{
  "connector": {
    "groupId": "distributed-oracle-sink-connector",
    "topics": ["distributed-oracle-sink-data-topic"],
    "tasks": 1,
    "paused": false,
    "disabled": false,
    "processors": {
      "1": {
        "name": "Kafka.Connect.Processors.WhitelistFieldProjector",
        "settings": [
          "userId",
          "userName",
          "email",
          "timestamp",
          "action"
        ]
      }
    },
    "plugin": {
      "type": "sink",
      "name": "oracle",
      "handler": "Kafka.Connect.Oracle.OraclePluginHandler",
      "strategy": {
        "Name": "Kafka.Connect.Oracle.Strategies.UpsertStrategy"
      },
      "properties": {
        "host": "oracle",
        "port": 1521,
        "userId": "system",
        "password": "oracle123",
        "serviceName": "XE",
        "schema": "\"SYSTEM\"",
        "table": "\"distributed_oracle_sink_data_table\"",
        "lookup": "\"userId\"='#userId#'",
        "filter": "\"userId\"='#userId#'"
      }
    },
    "log": {
      "provider": "",
      "attributes": [
        "userId",
        "userName"
      ]
    }
  },
  "workers": [
    "distributed-worker"
  ]
}
