{
  "urls": "http://localhost:7000/",
  "Serilog": {
    "MinimumLevel": {
      "Override": {
        "Kafka.Connect.Leader": "Information",
        "Kafka.Connect.Connectors.LeaderTask": "Information"
      }
    }
  },
  "leader": {
    "name": "kafka-connect-leader",
    "bootstrapServers": "127.0.0.1:9093",
    "securityProtocol": "PlainText",
    "enableAutoCommit": true,
    "enableAutoOffsetStore": false,
    "enablePartitionEof": true,
    "fetchWaitMaxMs": 50,
    "autoOffsetReset": "earliest",
    "maxPollIntervalMs": 300000,
    "settings": "./settings-leader",
    "topics": {
      "config": "__kafka_connect_dotnet_settings",
      "command": "__kafka_connect_dotnet_command"
    },
    "schemaRegistry": {
      "connectionTimeoutMs": 5000,
      "maxCachedSchemas": 10,
      "url": "http://localhost:28081"
    },
    "converters": {
      "key": "Kafka.Connect.Converters.JsonConverter",
      "value": "Kafka.Connect.Converters.JsonConverter"
    },
    "restarts": {
      "enabled": "Leader,Connector",
      "attempts": 5,
      "periodicDelayMs": 500,
      "stopOnFailure": false
    },
    "faultTolerance": {
      "retries": {
        "attempts": 3,
        "interval": 1000
      }
    }
  }
}
